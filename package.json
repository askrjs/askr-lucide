{
  "name": "@askrjs/lucide",
  "version": "0.0.1",
  "description": "Thin Askr wrappers for the Lucide SVG icon set",
  "keywords": [
    "askr",
    "askrjs",
    "components",
    "icons",
    "lucide",
    "svg"
  ],
  "homepage": "https://github.com/askrjs/askr-lucide#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-lucide/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/askrjs/askr-lucide.git"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run generate && vp pack",
    "dev": "npm run generate && vp pack --watch",
    "fmt": "vp fmt .",
    "generate": "node scripts/generate.js",
    "lint": "vp lint .",
    "prepublishOnly": "npm run build",
    "test": "npm run test:unit",
    "test:types": "npm run generate && tsc -p tsconfig.build.json --noEmit",
    "test:unit": "vp test run -c vitest.config.ts"
  },
  "devDependencies": {
    "@askrjs/askr": ">=0.0.30 <0.1.0",
    "jsdom": "^29.1.0",
    "lucide": "latest",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.19"
  },
  "peerDependencies": {
    "@askrjs/askr": ">=0.0.30 <0.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
